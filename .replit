[[workflows.workflow]]
name = "Backend-Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && dart pub get && dart run bin/server.dart"
waitForPort = 3000

[[workflows.workflow]]
name = "KM-Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && PORT=5000 dart run bin/server.dart"
waitForPort = 5000

[[workflows.workflow]]
name = "KM-Backend-Prod"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && dart run bin/server.dart"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80
