modules = ["python-3.11", "flutter", "postgresql-16", "dart"]

[nix]
channel = "stable-24_05"
packages = ["SDL2", "SDL2_image", "SDL2_mixer", "SDL2_ttf", "dart", "glibcLocales", "gt", "jq", "libcxx", "mtdev", "pkg-config", "postgresql", "fly", "k3s_1_28"]

[deployment]
deploymentTarget = "autoscale"
run = ["streamlit", "run", "app.py", "--server.port", "5000"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Run Flutter"
author = 40507595
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export PATH=\"$PATH:/opt/flutter/bin\""

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "flutter pub get"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "flutter run --web-port=5000 --web-hostname=0.0.0.0"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "FlyDeploy"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "FlyDeployFixed"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend-Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "KM-Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "KM-Backend-Prod"

[[workflows.workflow]]
name = "FlyDeploy"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && export FLY_ACCESS_TOKEN=\"FlyV1 fm2_,fm2_lJPETvakJGEgi3R2KddVN8YCt2bPfDi8XLLBiY9bGJ4TQRJgc9rqsPxywA3F9R7mHtrEHs5X7iJVa8/XIqs6ZKuNmJvCRE5OYhWamUk5c6X26sQQPzqFpoe8TI5PQqtd+Keo38O5aHR0cHM6Ly9hcGkuZmx5LmlvL2FhYS92MZgEks5ogQuizwAAAAEkeSnAF84AEYXNCpHOABGFzQzEEGEqYTD7frBfNvjswLBshrvEIE7wgo4IIw3WUISR7R2dOkIlAeQL6Iwnu+e9lVyJ/hv7\" && $HOME/.fly/bin/flyctl logs --app moto"

