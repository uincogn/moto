# Configurações do Servidor Dart
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Banco de Dados PostgreSQL  
DATABASE_URL=postgresql://motouber_user:senha123@localhost:5432/motouber
DB_HOST=localhost
DB_PORT=5432
DB_NAME=motouber
DB_USER=motouber_user  
DB_PASS=senha123

# JWT (Dart jose package)
JWT_SECRET=seu_jwt_secret_muito_seguro_dart_backend_aqui
JWT_EXPIRES_IN=7d
JWT_ISSUER=motouber_api

# Pagamentos - PagSeguro
PAGSEGURO_TOKEN=seu_token_pagseguro_aqui
PAGSEGURO_SANDBOX=true
PAGSEGURO_NOTIFICATION_URL=https://api.motouber.com/api/premium/webhook

# Pagamentos - Stripe (opcional)
STRIPE_SECRET_KEY=sk_test_seu_stripe_secret_aqui
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret

# Email/SMS (opcional para notificações)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@motouber.com
SMTP_PASS=sua_senha_app_gmail

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MINUTES=15

# Backup/Sincronização
MAX_BACKUP_SIZE_MB=10
BACKUP_RETENTION_DAYS_FREE=30
BACKUP_RETENTION_DAYS_PREMIUM=-1